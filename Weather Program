void func_WindChill (double& tempF, double& WindMPH, double& WindChill, double& error) {
    
    WindChill = 35.74 + 0.62 * tempF - 35.75 * pow(WindMPH, 0.16) + 0.4275 * tempF * pow(WindMPH, 0.16);
    
    cout<< "                             Your Wind chill is:\n                          ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n" <<"                             "<< WindChill << " degrees fahrenheit.";
    
